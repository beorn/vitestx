    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "debug": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "@silvery/react": ">=0.1.0",
    "decant": ">=0.1.0",
    "react": ">=19.0.0",
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@silvery/react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "decant": {
      "optional": true
    }
  }
