{
  "name": "vitestx",
  "version": "0.2.0",
  "description": "Vitest extension with fuzz testing",
  "keywords": [
    "fuzz",
    "fuzzing",
    "property-based-testing",
    "testing",
    "vitest"
  ],
  "homepage": "https://beorn.github.io/vitestx/",
  "bugs": {
    "url": "https://github.com/beorn/vitestx/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/vitestx.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts",
    "./fuzz": "./src/fuzz/index.ts",
    "./chaos": "./src/chaos/index.ts",
    "./dotz": "./src/dotz/index.tsx"
